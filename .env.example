# API Keys - DO NOT COMMIT ACTUAL VALUES
# Copy this file to .env.local and fill in your actual keys

# Groq API Keys (for LLM generation)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_SECONDARY=your_groq_secondary_key_here

# Google Gemini API Keys (for LLM generation fallback)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_SECONDARY=your_gemini_secondary_key_here

# Firebase Configuration
FIREBASE_PROJECT_ID=intai-a71d8
FIREBASE_PRIVATE_KEY=your_firebase_private_key_here
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@intai-a71d8.iam.gserviceaccount.com

# Environment
NODE_ENV=production
PORT=3000
